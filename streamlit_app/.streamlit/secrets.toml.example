# Copiar a secrets.toml (local) o configurar en Streamlit Cloud
# NUNCA commitear secrets.toml al repositorio

WC_URL = "https://tu-tienda.com"
WC_KEY = "ck_..."
WC_SECRET = "cs_..."

# URL base de GitHub Pages donde se publican los JSON de datos
NETLIFY_DATA_URL = "https://tu-org.github.io/tu-repo"

# Backend FastAPI (Cloudflare Tunnel o URL local)
# Si está vacío, la app funciona en modo solo lectura (Netlify)
BACKEND_URL = ""
API_KEY = ""

# Usuarios: cada seccion [users.nombre] define un usuario
[users.admin]
password = "contraseña"
role = "admin"
name = "Nombre Admin"

[users.socio1]
password = "contraseña"
role = "socio"
name = "Nombre Socio"
