# Copiar a secrets.toml (local) o configurar en Streamlit Cloud
# NUNCA commitear secrets.toml al repositorio

WC_URL = "https://tu-tienda.com"
WC_KEY = "ck_..."
WC_SECRET = "cs_..."

# URL base de Netlify donde se publican los JSON de datos
NETLIFY_DATA_URL = "https://tu-site.netlify.app"

# Usuarios: cada seccion [users.nombre] define un usuario
[users.admin]
password = "contraseña"
role = "admin"
name = "Nombre Admin"

[users.socio1]
password = "contraseña"
role = "socio"
name = "Nombre Socio"
